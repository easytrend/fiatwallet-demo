# ─── Solana RPC Endpoint ─────────────────────────────────────────────────────
# Use a premium RPC (Helius, QuickNode, Alchemy) for mainnet reliability
VITE_RPC_URL=https://api.mainnet-beta.solana.com

# ─── PajCash Off-Ramp Gateway ─────────────────────────────────────────────────
# Your Business API Key from the PajCash merchant dashboard (https://paj.cash)
# This is the only credential needed — no email/OTP required.
VITE_PAJCASH_API_KEY=

# Environment: 'production' | 'staging' | 'local'
VITE_PAJCASH_ENV=production

# Optional: Webhook URL to receive transaction status updates
VITE_PAJCASH_WEBHOOK_URL=
